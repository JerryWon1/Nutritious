{
  "name": "nutritious-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.content.config.ts",
    "build:content": "vite build --config vite.content.config.ts",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "extract-pdf": "node scripts/extractPdfText.mjs",
    "package": "npm run build && mkdir -p releases && rm -f releases/nutritious-extension-0.1.0-alpha.zip && (cd dist && zip -r ../releases/nutritious-extension-0.1.0-alpha.zip .)"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.315",
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38"
  }
}
